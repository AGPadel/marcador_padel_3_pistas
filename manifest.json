<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1,maximum-scale=1,user-scalable=no,viewport-fit=cover">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<meta name="theme-color" content="#0f172a">
<link rel="manifest" href="./manifest.json">
<title>AG Pádel · Marcador</title>
<style>
:root {
  --bg: #0f172a;
  --surface: #1e293b;
  --surface2: #263348;
  --border: rgba(255,255,255,0.07);
  --text: #f1f5f9;
  --muted: #64748b;
  --accent: #c9a84c;
  --accent-dim: rgba(201,168,76,0.15);
  --t1: #3b82f6;
  --t1-dim: rgba(59,130,246,0.12);
  --t2: #ef4444;
  --t2-dim: rgba(239,68,68,0.12);
  --green: #22c55e;
  --radius: 16px;
}
*{box-sizing:border-box;margin:0;padding:0;-webkit-tap-highlight-color:transparent;user-select:none;}
html,body{width:100%;height:100%;overflow:hidden;background:var(--bg);color:var(--text);font-family:-apple-system,'SF Pro Display','Helvetica Neue',sans-serif;}

/* ── SETUP SCREEN ── */
.setup{position:fixed;inset:0;background:var(--bg);z-index:500;display:flex;flex-direction:column;align-items:center;justify-content:center;padding:24px;gap:0;}
.setup.hidden{display:none;}
.setup-logo{font-size:2.5rem;margin-bottom:8px;}
.setup-title{font-size:1.6rem;font-weight:800;letter-spacing:3px;text-transform:uppercase;color:var(--text);margin-bottom:4px;}
.setup-sub{font-size:0.72rem;letter-spacing:3px;text-transform:uppercase;color:var(--muted);margin-bottom:32px;}
.setup-card{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);padding:24px;width:100%;max-width:400px;display:flex;flex-direction:column;gap:16px;}
.setup-section{display:flex;flex-direction:column;gap:8px;}
.setup-label{font-size:0.6rem;letter-spacing:3px;text-transform:uppercase;font-weight:700;}
.setup-label.l1{color:var(--t1);}
.setup-label.l2{color:var(--t2);}
.setup-input{background:var(--surface2);border:1px solid var(--border);border-radius:10px;color:var(--text);font-size:1rem;font-weight:600;letter-spacing:1px;padding:12px 14px;outline:none;width:100%;text-transform:uppercase;}
.setup-input::placeholder{color:var(--muted);font-weight:400;text-transform:none;}
.setup-input:focus{border-color:var(--accent);}
.setup-divider{height:1px;background:var(--border);}
.setup-row{display:flex;align-items:center;justify-content:space-between;}
.setup-row-label{font-size:0.78rem;color:var(--text);font-weight:600;}
.setup-row-sub{font-size:0.65rem;color:var(--muted);margin-top:2px;}
.toggle{position:relative;width:44px;height:26px;flex-shrink:0;}
.toggle input{opacity:0;width:0;height:0;}
.ttrack{position:absolute;inset:0;background:#334155;border-radius:13px;cursor:pointer;transition:background .2s;}
.toggle input:checked+.ttrack{background:var(--accent);}
.ttrack::after{content:'';position:absolute;width:20px;height:20px;border-radius:50%;background:#fff;top:3px;left:3px;transition:transform .2s;box-shadow:0 1px 3px rgba(0,0,0,.3);}
.toggle input:checked+.ttrack::after{transform:translateX(18px);}
.setup-pista{display:flex;gap:8px;}
.pista-btn{flex:1;background:var(--surface2);border:2px solid var(--border);border-radius:10px;color:var(--muted);font-size:0.75rem;font-weight:700;letter-spacing:2px;text-transform:uppercase;padding:10px;cursor:pointer;transition:all .2s;text-align:center;}
.pista-btn.sel{border-color:var(--accent);color:var(--accent);background:var(--accent-dim);}
.setup-start{background:var(--accent);border:none;color:#0f172a;font-size:1rem;font-weight:800;letter-spacing:3px;text-transform:uppercase;padding:16px;border-radius:12px;cursor:pointer;width:100%;transition:opacity .15s;}
.setup-start:active{opacity:.85;}

/* ── MAIN APP ── */
.app{width:100vw;height:100dvh;display:flex;flex-direction:column;overflow:hidden;}

/* TOPBAR */
.topbar{height:52px;display:flex;align-items:center;justify-content:space-between;padding:0 14px;flex-shrink:0;border-bottom:1px solid var(--border);background:rgba(15,23,42,.9);backdrop-filter:blur(12px);position:relative;z-index:10;}
.tb-left{display:flex;gap:6px;}
.tb-center{font-size:0.75rem;font-weight:700;letter-spacing:4px;text-transform:uppercase;color:var(--muted);}
.tb-right{display:flex;gap:6px;}
.tb-btn{background:var(--surface);border:1px solid var(--border);border-radius:9px;width:36px;height:36px;font-size:1rem;display:flex;align-items:center;justify-content:center;cursor:pointer;color:var(--muted);transition:all .15s;}
.tb-btn:active{background:var(--surface2);color:var(--text);}
.timer-btn{min-width:72px;font-family:ui-monospace,'SF Mono',monospace;font-size:0.82rem;font-weight:700;letter-spacing:2px;color:var(--muted);}
.timer-btn.on{color:var(--green);}

/* BOARD */
.board{flex:1;display:grid;grid-template-columns:1fr auto 1fr;min-height:0;position:relative;}

/* ZONE */
.zone{display:flex;flex-direction:column;align-items:center;justify-content:center;cursor:pointer;position:relative;overflow:hidden;padding:12px 8px;}
.zone::after{content:'';position:absolute;inset:0;opacity:0;transition:opacity .15s;}
.zone.z1::after{background:var(--t1-dim);}
.zone.z2::after{background:var(--t2-dim);}
.zone:active::after{opacity:1;}

/* flash */
.zflash{position:absolute;inset:0;pointer-events:none;opacity:0;}
.zflash.go{animation:gf .55s ease-out forwards;}
@keyframes gf{0%{opacity:.35}100%{opacity:0}}
.z1 .zflash{background:var(--t1);}
.z2 .zflash{background:var(--t2);}

/* serve */
.serve-dot{width:10px;height:10px;border-radius:50%;background:var(--green);margin-bottom:8px;opacity:0;box-shadow:0 0 8px var(--green);transition:opacity .3s;}
.zone.srv .serve-dot{opacity:1;}

/* name */
.zname{font-size:clamp(.5rem,1.8vw,.72rem);font-weight:700;letter-spacing:3px;text-transform:uppercase;color:var(--muted);margin-bottom:6px;text-align:center;}
.zone.srv .zname{color:var(--green);}

/* big points */
.zpt{font-size:min(40vw,72vh);font-weight:900;line-height:.82;color:var(--text);text-align:center;transition:transform .12s;}
.z1 .zpt{color:var(--t1);}
.z2 .zpt{color:var(--t2);}
.zpt.bump{animation:bump .2s cubic-bezier(.34,1.56,.64,1);}
@keyframes bump{0%{transform:scale(1.22)}100%{transform:scale(1)}}

/* games */
.zgames{font-size:clamp(1.2rem,5vw,3rem);font-weight:900;color:rgba(255,255,255,.1);margin-top:8px;}
.zone.srv .zgames{color:rgba(34,197,94,.2);}
.zlbl{font-size:.42rem;letter-spacing:3px;text-transform:uppercase;color:rgba(255,255,255,.08);margin-top:2px;}

/* CENTER PANEL */
.center-panel{width:clamp(90px,14vw,130px);display:flex;flex-direction:column;align-items:center;justify-content:center;gap:8px;border-left:1px solid var(--border);border-right:1px solid var(--border);padding:10px 6px;flex-shrink:0;}
.sets-display{background:var(--surface);border-radius:12px;padding:8px 10px;display:flex;align-items:center;gap:6px;width:100%;justify-content:center;}
.sd-num{font-size:clamp(1.2rem,3vw,2rem);font-weight:900;line-height:1;}
.sd-num.c1{color:var(--t1);}
.sd-num.c2{color:var(--t2);}
.sd-dash{font-size:.5rem;color:#334155;}
.set-hist{background:var(--surface);border-radius:10px;padding:6px 8px;width:100%;}
.sh-row{display:grid;grid-template-columns:1fr auto 1fr;align-items:center;gap:2px;padding:2px 0;}
.sh-row:not(:last-child){border-bottom:1px solid var(--border);margin-bottom:2px;padding-bottom:3px;}
.sh-v{font-size:clamp(.8rem,2vw,1.2rem);font-weight:900;text-align:center;color:var(--muted);}
.sh-v.w1{color:var(--t1);}
.sh-v.w2{color:var(--t2);}
.sh-v.cur{color:var(--text);}
.sh-d{font-size:.4rem;color:#334155;text-align:center;}
.pista-badge{font-size:.52rem;letter-spacing:3px;text-transform:uppercase;color:#334155;font-weight:700;}

/* BOTTOMBAR */
.bottombar{height:56px;display:flex;align-items:stretch;border-top:1px solid var(--border);flex-shrink:0;background:rgba(15,23,42,.9);}
.bb-undo{background:none;border:none;border-right:1px solid var(--border);display:flex;flex-direction:column;align-items:center;justify-content:center;gap:2px;padding:0 20px;cursor:pointer;color:var(--muted);transition:all .15s;flex-shrink:0;}
.bb-undo:active{background:rgba(239,68,68,.1);color:#ef4444;}
.bb-undo .ico{font-size:1.1rem;}
.bb-undo .lbl{font-size:.38rem;letter-spacing:2px;text-transform:uppercase;}
.bb-space{flex:1;}
.bb-right{display:flex;}
.bb-btn{background:none;border:none;border-left:1px solid var(--border);color:var(--muted);font-size:.95rem;width:54px;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:1px;cursor:pointer;transition:background .15s;}
.bb-btn:active{background:var(--surface);}
.bb-btn small{font-size:.36rem;letter-spacing:1px;text-transform:uppercase;}

/* TOAST */
.toast{position:fixed;top:50%;left:50%;transform:translate(-50%,-50%) scale(.9);background:rgba(30,41,59,.97);border:1px solid var(--border);color:var(--text);border-radius:14px;font-size:1rem;font-weight:700;letter-spacing:2px;padding:14px 24px;opacity:0;transition:opacity .15s,transform .15s;pointer-events:none;z-index:200;white-space:nowrap;backdrop-filter:blur(12px);}
.toast.show{opacity:1;transform:translate(-50%,-50%) scale(1);}

/* PANELS */
.overlay{position:fixed;inset:0;background:rgba(0,0,0,.6);z-index:300;display:none;align-items:flex-end;backdrop-filter:blur(4px);}
.overlay.show{display:flex;}
.sheet{background:var(--surface);border-radius:22px 22px 0 0;width:100%;padding:14px 16px 40px;display:flex;flex-direction:column;gap:12px;max-height:88vh;overflow-y:auto;animation:shUp .26s cubic-bezier(.34,1.2,.64,1);}
@keyframes shUp{from{transform:translateY(100%)}to{transform:translateY(0)}}
.sh-handle{width:36px;height:3px;background:#334155;border-radius:2px;margin:0 auto 4px;}
.sh-head{display:flex;align-items:center;justify-content:space-between;}
.sh-title{font-size:1.1rem;font-weight:800;letter-spacing:2px;text-transform:uppercase;color:var(--text);}
.sh-close{background:var(--surface2);border:none;border-radius:50%;width:32px;height:32px;font-size:.9rem;display:flex;align-items:center;justify-content:center;cursor:pointer;color:var(--muted);}
.sh-div{height:1px;background:var(--border);}
.set-row{display:flex;align-items:center;justify-content:space-between;padding:8px 0;}
.sr-info{display:flex;flex-direction:column;gap:2px;flex:1;padding-right:14px;}
.sr-label{font-weight:700;font-size:.82rem;color:var(--text);}
.sr-desc{font-size:.65rem;color:var(--muted);line-height:1.4;}
.srv-pick{display:flex;gap:8px;}
.sp-btn{flex:1;background:var(--surface2);border:2px solid var(--border);border-radius:10px;padding:10px;cursor:pointer;font-size:.78rem;font-weight:700;letter-spacing:1px;color:var(--text);text-align:center;transition:all .2s;}
.sp-btn.sel1{border-color:var(--t1);background:var(--t1-dim);color:var(--t1);}
.sp-btn.sel2{border-color:var(--t2);background:var(--t2-dim);color:var(--t2);}
.sh-btn{background:var(--accent);border:none;color:#0f172a;font-size:.9rem;font-weight:800;letter-spacing:2px;text-transform:uppercase;padding:13px;border-radius:11px;cursor:pointer;width:100%;}
.sh-btn.secondary{background:var(--surface2);color:var(--muted);}

/* WIN */
.win{position:fixed;inset:0;background:linear-gradient(160deg,#0a0f1e,#0f172a);z-index:400;display:none;flex-direction:column;align-items:center;justify-content:center;gap:12px;padding:32px;text-align:center;}
.win.show{display:flex;}
.win-trophy{font-size:3.5rem;animation:float 2s ease-in-out infinite alternate;}
@keyframes float{from{transform:translateY(0)}to{transform:translateY(-12px)}}
.win-lbl{font-size:.65rem;letter-spacing:5px;text-transform:uppercase;color:var(--muted);}
.win-name{font-size:clamp(2rem,8vw,4rem);font-weight:900;letter-spacing:3px;text-transform:uppercase;}
.win-name.c1{color:var(--t1);}
.win-name.c2{color:var(--t2);}
.win-sets{font-size:1.4rem;font-weight:700;color:var(--muted);letter-spacing:6px;margin-top:4px;}
.win-time{font-family:ui-monospace,monospace;font-size:.78rem;color:#334155;letter-spacing:3px;}
.win-btn{margin-top:16px;background:var(--surface);border:1px solid var(--border);color:var(--text);font-size:.9rem;font-weight:700;letter-spacing:3px;text-transform:uppercase;padding:14px 32px;border-radius:12px;cursor:pointer;}

/* SERVE MODAL */
.modal{position:fixed;inset:0;background:rgba(0,0,0,.8);z-index:600;display:none;align-items:center;justify-content:center;padding:24px;backdrop-filter:blur(8px);}
.modal.show{display:flex;}
.modal-box{background:var(--surface);border:1px solid var(--border);border-radius:20px;padding:24px 18px;width:100%;max-width:320px;display:flex;flex-direction:column;gap:12px;}
.modal-title{font-size:1.2rem;font-weight:800;letter-spacing:2px;text-transform:uppercase;text-align:center;color:var(--text);}
.modal-sub{font-size:.72rem;color:var(--muted);text-align:center;}
.modal-btn{background:var(--surface2);border:2px solid var(--border);border-radius:13px;padding:16px;cursor:pointer;text-align:center;transition:all .2s;}
.modal-btn.t1{border-color:var(--t1);background:var(--t1-dim);}
.modal-btn.t2{border-color:var(--t2);background:var(--t2-dim);}
.modal-name{font-size:1.1rem;font-weight:800;letter-spacing:2px;text-transform:uppercase;color:var(--text);}
.modal-hint{font-size:.58rem;color:var(--muted);margin-top:3px;}
</style>
</head>
<body>

<!-- SETUP SCREEN -->
<div class="setup" id="setup">
  <div class="setup-logo">🎾</div>
  <div class="setup-title">AG Pádel</div>
  <div class="setup-sub">Configurar partido</div>
  <div class="setup-card">
    <div class="setup-section">
      <div class="setup-label l1">Pareja A</div>
      <input class="setup-input" id="s-n1a" placeholder="Jugador 1" maxlength="14">
      <input class="setup-input" id="s-n1b" placeholder="Jugador 2" maxlength="14">
    </div>
    <div class="setup-divider"></div>
    <div class="setup-section">
      <div class="setup-label l2">Pareja B</div>
      <input class="setup-input" id="s-n2a" placeholder="Jugador 1" maxlength="14">
      <input class="setup-input" id="s-n2b" placeholder="Jugador 2" maxlength="14">
    </div>
    <div class="setup-divider"></div>
    <div class="setup-section">
      <div class="setup-row">
        <div><div class="setup-row-label">Punto de oro</div><div class="setup-row-sub">A 40-40 gana el siguiente punto</div></div>
        <label class="toggle"><input type="checkbox" id="s-gold" checked><div class="ttrack"></div></label>
      </div>
      <div class="setup-row">
        <div><div class="setup-row-label">Mejor de 5 sets</div><div class="setup-row-sub">Por defecto: mejor de 3</div></div>
        <label class="toggle"><input type="checkbox" id="s-bo5"><div class="ttrack"></div></label>
      </div>
    </div>
    <div class="setup-divider"></div>
    <div class="setup-section">
      <div class="setup-label" style="color:var(--muted)">Pista</div>
      <div class="setup-pista">
        <button class="pista-btn sel" data-p="1" onclick="selPista(this)">1</button>
        <button class="pista-btn" data-p="2" onclick="selPista(this)">2</button>
        <button class="pista-btn" data-p="3" onclick="selPista(this)">3</button>
      </div>
    </div>
    <button class="setup-start" onclick="startMatch()">Iniciar partido →</button>
  </div>
</div>

<!-- MAIN APP -->
<div class="app" id="app" style="display:none">
  <div class="topbar">
    <div class="tb-left">
      <button class="tb-btn" onclick="undoPoint()" title="Deshacer">↩</button>
    </div>
    <div class="tb-center" id="tb-pista">PISTA 1</div>
    <div class="tb-right">
      <button class="tb-btn timer-btn" id="timer-btn" onclick="timerTap()">00:00</button>
      <button class="tb-btn" onclick="showPanel('settings')">⚙</button>
    </div>
  </div>

  <div class="board">
    <div class="zone z1" id="z1" onclick="addPoint(1)">
      <div class="zflash" id="fl1"></div>
      <div class="serve-dot"></div>
      <div class="zname" id="nm1">PAREJA A</div>
      <div class="zpt" id="pt1">0</div>
      <div class="zgames" id="gm1">0</div>
      <div class="zlbl">juegos</div>
    </div>

    <div class="center-panel">
      <div class="pista-badge" id="cp-pista">P1</div>
      <div class="sets-display">
        <span class="sd-num c1" id="ts1">0</span>
        <span class="sd-dash">–</span>
        <span class="sd-num c2" id="ts2">0</span>
      </div>
      <div class="set-hist" id="set-hist"></div>
    </div>

    <div class="zone z2" id="z2" onclick="addPoint(2)">
      <div class="zflash" id="fl2"></div>
      <div class="serve-dot"></div>
      <div class="zname" id="nm2">PAREJA B</div>
      <div class="zpt" id="pt2">0</div>
      <div class="zgames" id="gm2">0</div>
      <div class="zlbl">juegos</div>
    </div>
  </div>

  <div class="bottombar">
    <button class="bb-undo" onclick="undoPoint()">
      <span class="ico">↩</span><span class="lbl">Deshacer</span>
    </button>
    <div class="bb-space"></div>
    <div class="bb-right">
      <button class="bb-btn" onclick="showPanel('settings')">⚙<small>Ajustes</small></button>
      <button class="bb-btn" onclick="resetMatch()">↺<small>Reset</small></button>
    </div>
  </div>
</div>

<div class="toast" id="toast"></div>

<!-- SERVE MODAL -->
<div class="modal" id="modal-serve">
  <div class="modal-box">
    <div class="modal-title">🎾 ¿Quién saca?</div>
    <div class="modal-sub">Rotará automáticamente cada juego</div>
    <button class="modal-btn t1" onclick="selectServe(1)">
      <div class="modal-name" id="mn1">PAREJA A</div>
      <div class="modal-hint">Saca primero</div>
    </button>
    <button class="modal-btn t2" onclick="selectServe(2)">
      <div class="modal-name" id="mn2">PAREJA B</div>
      <div class="modal-hint">Saca primero</div>
    </button>
  </div>
</div>

<!-- SETTINGS PANEL -->
<div class="overlay" id="settings-panel" onclick="backdropClose('settings-panel',event)">
  <div class="sheet">
    <div class="sh-handle"></div>
    <div class="sh-head">
      <div class="sh-title">Ajustes</div>
      <button class="sh-close" onclick="hidePanel('settings-panel')">✕</button>
    </div>
    <div class="set-row">
      <div class="sr-info"><div class="sr-label">Saque</div><div class="sr-desc">Cambiar quién saca ahora</div></div>
    </div>
    <div class="srv-pick">
      <button class="sp-btn" id="spbtn1" onclick="forceServe(1)"></button>
      <button class="sp-btn" id="spbtn2" onclick="forceServe(2)"></button>
    </div>
    <div class="sh-div"></div>
    <div class="set-row">
      <div class="sr-info"><div class="sr-label">Punto de oro</div><div class="sr-desc">A 40-40 gana el siguiente punto</div></div>
      <label class="toggle"><input type="checkbox" id="cfg-gold" onchange="saveCfg()"><div class="ttrack"></div></label>
    </div>
    <div class="sh-div"></div>
    <button class="sh-btn" onclick="showSetupFromSettings()">✎ Editar nombres</button>
    <button class="sh-btn secondary" onclick="hidePanel('settings-panel')">Cerrar</button>
  </div>
</div>

<!-- WIN -->
<div class="win" id="win">
  <div class="win-trophy">🏆</div>
  <div class="win-lbl">Partido ganado por</div>
  <div class="win-name" id="wname"></div>
  <div class="win-sets" id="wsets"></div>
  <div class="win-time" id="wtime"></div>
  <button class="win-btn" onclick="resetMatch()">Nuevo partido</button>
</div>

<script>
'use strict';

// ── STATE ──
let pista = 1;
let names = ['PAREJA A', 'PAREJA B'];
let pts = [0,0], games = [0,0], sets = [0,0];
let setHist = [];
let server = 0;
let matchOver = false;
let totalGames = 0;
let gold = true;
let bo5 = false;
let tiebreak = false;
let undoStack = [];
let elapsed = 0;
let timerRef = null, timerStart = null;
let startTimestamp = null;

const PTLBL = ['0','15','30','40'];
const setsToWin = () => bo5 ? 3 : 2;

// ── SETUP ──
let selectedPista = 1;
function selPista(el) {
  document.querySelectorAll('.pista-btn').forEach(b => b.classList.remove('sel'));
  el.classList.add('sel');
  selectedPista = parseInt(el.dataset.p);
}

function startMatch() {
  const n1a = document.getElementById('s-n1a').value.trim().toUpperCase() || 'PAREJA A';
  const n1b = document.getElementById('s-n1b').value.trim().toUpperCase() || '';
  const n2a = document.getElementById('s-n2a').value.trim().toUpperCase() || 'PAREJA B';
  const n2b = document.getElementById('s-n2b').value.trim().toUpperCase() || '';
  names[0] = n1b ? n1a + ' / ' + n1b : n1a;
  names[1] = n2b ? n2a + ' / ' + n2b : n2a;
  gold = document.getElementById('s-gold').checked;
  bo5  = document.getElementById('s-bo5').checked;
  pista = selectedPista;
  document.getElementById('setup').classList.add('hidden');
  document.getElementById('app').style.display = 'flex';
  document.getElementById('tb-pista').textContent = 'PISTA ' + pista;
  document.getElementById('cp-pista').textContent = 'P' + pista;
  document.getElementById('cfg-gold').checked = gold;
  resetState(true);
  render();
  setTimeout(showServeModal, 400);
}

function showSetupFromSettings() {
  hidePanel('settings-panel');
  document.getElementById('setup').classList.remove('hidden');
  document.getElementById('app').style.display = 'none';
}

// ── RESET ──
function resetState(full) {
  pts=[0,0]; games=[0,0]; sets=[0,0];
  setHist=[]; undoStack=[]; totalGames=0;
  matchOver=false; tiebreak=false;
  if (full) { server=0; stopTimer(); elapsed=0; timerStart=null; startTimestamp=null; }
}

function resetMatch() {
  document.getElementById('win').classList.remove('show');
  resetState(true);
  clearMatch();
  render();
  setTimeout(showServeModal, 300);
}

// ── SERVE ──
function showServeModal() {
  document.getElementById('mn1').textContent = names[0];
  document.getElementById('mn2').textContent = names[1];
  document.getElementById('modal-serve').classList.add('show');
}
function selectServe(t) {
  server = t;
  document.getElementById('modal-serve').classList.remove('show');
  render(); save();
}
function forceServe(t) {
  server = t;
  hidePanel('settings-panel');
  render(); save();
}
function rotateServe() { server = server === 1 ? 2 : 1; }

// ── TIMER ──
function startTimer() {
  if (timerRef) return;
  if (!startTimestamp) startTimestamp = Date.now() - elapsed * 1000;
  timerStart = startTimestamp;
  timerRef = setInterval(() => {
    elapsed = Math.floor((Date.now() - timerStart) / 1000);
    const el = document.getElementById('timer-btn');
    el.textContent = fmt(elapsed);
    el.classList.add('on');
  }, 1000);
}
function stopTimer() { clearInterval(timerRef); timerRef = null; }
function fmt(s) { return String(Math.floor(s/60)).padStart(2,'0')+':'+String(s%60).padStart(2,'0'); }
let tapCount = 0, tapTimer;
function timerTap() {
  tapCount++;
  clearTimeout(tapTimer);
  tapTimer = setTimeout(() => { tapCount = 0; }, 600);
  if (tapCount >= 5) { tapCount = 0; showToast('Debug: pts='+pts+' g='+games+' s='+sets); }
}

// ── SCORING ──
function snapshot() {
  return {
    pts: pts.slice(), games: games.slice(), sets: sets.slice(),
    setHist: setHist.map(x=>({...x})),
    server, totalGames, matchOver, tiebreak, elapsed,
    startTimestamp
  };
}
function restoreSnap(snap) {
  pts = snap.pts.slice(); games = snap.games.slice(); sets = snap.sets.slice();
  setHist = snap.setHist.map(x=>({...x}));
  server = snap.server; totalGames = snap.totalGames;
  matchOver = snap.matchOver; tiebreak = snap.tiebreak;
  elapsed = snap.elapsed; startTimestamp = snap.startTimestamp;
}

function addPoint(team) {
  if (matchOver) return;
  if (!server) { showServeModal(); return; }
  startTimer();
  undoStack.push(snapshot());
  if (undoStack.length > 25) undoStack.shift();

  const t = team - 1, o = 1 - t;
  let gameWon = false;

  if (tiebreak) {
    pts[t]++;
    const diff = Math.abs(pts[0] - pts[1]);
    if (pts[t] >= 7 && diff >= 2) gameWon = true;
    // serve changes every 2 points in tiebreak
    if ((pts[0] + pts[1]) % 2 === 1) rotateServe();
  } else if (gold) {
    if (pts[t] === 3) { gameWon = true; }
    else { pts[t]++; }
  } else {
    if (pts[t] === 3 && pts[o] === 3) { pts[t] = 4; }
    else if (pts[t] === 4) { gameWon = true; }
    else if (pts[o] === 4) { pts[o] = 3; }
    else if (pts[t] === 3) { gameWon = true; }
    else { pts[t]++; }
  }

  if (gameWon) {
    pts[0] = 0; pts[1] = 0;
    games[t]++; totalGames++;
    if (!tiebreak) rotateServe();
    tiebreak = false;

    const g0 = games[0], g1 = games[1], diff = Math.abs(g0 - g1);
    const tb = (g0 === 6 && g1 === 6);
    if (tb) { tiebreak = true; }
    const setOver = tb ? false : (g0 >= 6 || g1 >= 6) && diff >= 2;

    if (setOver) {
      setHist.push({ t1: games[0], t2: games[1] });
      sets[t]++;
      games[0] = 0; games[1] = 0;
      if (sets[t] >= setsToWin()) {
        matchOver = true;
        stopTimer();
        render(); save();
        setTimeout(() => showWin(team), 600);
        return;
      }
      showToast('Set · ' + names[t]);
    } else if (!tb) {
      showToast('Juego · ' + names[t]);
    }
  }

  render(); save();
  doFlash(team); doBump(team);
}

function undoPoint() {
  if (!undoStack.length) { showToast('Nada que deshacer'); return; }
  restoreSnap(undoStack.pop());
  render(); save();
  showToast('↩ Deshecho');
}

// ── RENDER ──
function render() {
  const p0=pts[0], p1=pts[1];
  const adv0 = !gold && p0===4, adv1 = !gold && p1===4;
  const isGold = gold && p0===3 && p1===3;

  if (tiebreak) {
    document.getElementById('pt1').textContent = p0;
    document.getElementById('pt2').textContent = p1;
  } else {
    document.getElementById('pt1').textContent = isGold?'🥇': adv0?'AD': adv1?'–': (PTLBL[p0]||'0');
    document.getElementById('pt2').textContent = isGold?'🥇': adv1?'AD': adv0?'–': (PTLBL[p1]||'0');
  }

  document.getElementById('gm1').textContent = games[0];
  document.getElementById('gm2').textContent = games[1];
  document.getElementById('nm1').textContent  = names[0];
  document.getElementById('nm2').textContent  = names[1];
  document.getElementById('ts1').textContent  = sets[0];
  document.getElementById('ts2').textContent  = sets[1];

  document.getElementById('z1').className = 'zone z1'+(server===1?' srv':'');
  document.getElementById('z2').className = 'zone z2'+(server===2?' srv':'');

  const sp1=document.getElementById('spbtn1'), sp2=document.getElementById('spbtn2');
  if(sp1){sp1.textContent=names[0];sp1.className='sp-btn'+(server===1?' sel1':'');}
  if(sp2){sp2.textContent=names[1];sp2.className='sp-btn'+(server===2?' sel2':'');}

  renderHist();
  publishState();
}

function renderHist() {
  let html = '';
  for (const s of setHist) {
    const w1=s.t1>s.t2, w2=s.t2>s.t1;
    html += `<div class="sh-row"><div class="sh-v ${w1?'w1':''}">${s.t1}</div><div class="sh-d">–</div><div class="sh-v ${w2?'w2':''}">${s.t2}</div></div>`;
  }
  html += `<div class="sh-row"><div class="sh-v cur">${games[0]}</div><div class="sh-d">–</div><div class="sh-v cur">${games[1]}</div></div>`;
  document.getElementById('set-hist').innerHTML = html;
}

// ── ANIMATIONS ──
function doFlash(t) {
  const el=document.getElementById('fl'+t);
  el.classList.remove('go'); void el.offsetWidth; el.classList.add('go');
}
function doBump(t) {
  const el=document.getElementById('pt'+t);
  el.classList.remove('bump'); void el.offsetWidth; el.classList.add('bump');
}
let toastT;
function showToast(msg) {
  clearTimeout(toastT);
  const el=document.getElementById('toast');
  el.textContent=msg; el.className='toast show';
  toastT=setTimeout(()=>el.className='toast',1800);
}

// ── WIN ──
function showWin(team) {
  document.getElementById('wname').textContent = names[team-1];
  document.getElementById('wname').className = 'win-name c'+team;
  document.getElementById('wsets').textContent = setHist.map(s=>s.t1+'-'+s.t2).join('  ');
  document.getElementById('wtime').textContent = '⏱ '+fmt(elapsed);
  document.getElementById('win').classList.add('show');
}

// ── PANELS ──
function showPanel(id) {
  document.getElementById(id+'-panel').classList.add('show');
}
function hidePanel(id) { document.getElementById(id).classList.remove('show'); }
function backdropClose(id, e) { if(e.target===document.getElementById(id)) hidePanel(id); }

// ── CFG ──
function saveCfg() {
  gold = document.getElementById('cfg-gold').checked;
}

// ── PERSISTENCE ──
const matchKey = () => 'ag_match_pista_' + pista;

function save() {
  try {
    const data = {
      names, pts, games, sets, setHist,
      server, totalGames, matchOver, tiebreak,
      elapsed, startTimestamp, gold, bo5, pista,
      savedAt: Date.now()
    };
    localStorage.setItem(matchKey(), JSON.stringify(data));
    // Broadcast to videowall
    try {
      new BroadcastChannel('agpadel').postMessage({ pista, state: data });
    } catch(e) {}
  } catch(e) {}
}

function clearMatch() {
  try { localStorage.removeItem(matchKey()); } catch(e) {}
}

function loadSaved() {
  try {
    const raw = localStorage.getItem(matchKey());
    if (!raw) return false;
    const d = JSON.parse(raw);
    if (Date.now() - (d.savedAt||0) > 43200000) return false;
    names=d.names; pts=d.pts; games=d.games; sets=d.sets;
    setHist=d.setHist||[]; server=d.server; totalGames=d.totalGames||0;
    matchOver=d.matchOver; tiebreak=d.tiebreak||false;
    elapsed=d.elapsed||0; startTimestamp=d.startTimestamp||null;
    gold=d.gold!==undefined?d.gold:true; bo5=d.bo5||false; pista=d.pista||1;
    return true;
  } catch(e) { return false; }
}

// ── PUBLISH STATE FOR VIDEOWALL ──
function publishState() {
  try {
    const data = {
      names, pts, games, sets, setHist,
      server, totalGames, matchOver, tiebreak,
      elapsed, startTimestamp, gold, bo5, pista,
      savedAt: Date.now()
    };
    localStorage.setItem('ag_match_pista_'+pista, JSON.stringify(data));
    try { new BroadcastChannel('agpadel').postMessage({ pista, state: data }); } catch(e) {}
  } catch(e) {}
}

// ── KEYBOARD ──
document.addEventListener('keydown', e => {
  if (e.key==='1') addPoint(1);
  else if (e.key==='2') addPoint(2);
  else if (e.key==='z'||e.key==='Z') undoPoint();
  else if (e.key==='Escape') document.querySelectorAll('.overlay.show,.modal.show').forEach(el=>el.classList.remove('show'));
});

// ── INIT ──
if ('serviceWorker' in navigator) navigator.serviceWorker.register('./sw.js').catch(()=>{});
try { if(navigator.wakeLock) navigator.wakeLock.request('screen').catch(()=>{}); } catch(e) {}
try { if(screen.orientation?.lock) screen.orientation.lock('landscape').catch(()=>{}); } catch(e) {}
</script>
</body>
</html>
